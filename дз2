from telegram import Update
from telegram.ext import ApplicationBuilder, CommandHandler, MessageHandler, filters, ContextTypes
import random

game_state = {}

words = ["питон", "бот", "телеграм", "программирование", "функция"]

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обрабатывает команду /start."""
    user_id = update.effective_user.id
    if user_id not in game_state:
        new_game(user_id)
    await update.message.reply_text(
        f"Привет, {update.effective_user.first_name}! Начинаем игру «Виселица».\n"
        f"Я загадал слово. Попробуй угадать его по буквам. У вас {game_state[user_id]['attempts']} попыток."
        f"\nСлово: {' '.join(game_state[user_id]['display_word'])}"
    )

def new_game(user_id):
    """Начинает новую игру для пользователя."""
    secret_word = random.choice(words)
    game_state[user_id] = {
        "secret_word": secret_word,
        "display_word": ["_"] * len(secret_word),
        "attempts": 6,
        "guessed_letters": set()
    }

async def guess(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обрабатывает предположения пользователя."""
    user_id = update.effective_user.id
    if user_id not in game_state:
        await update.message.reply_text("Начните игру с команды /start.")
        return

    guess_letter = update.message.text.lower()

    if len(guess_letter) != 1 or not guess_letter.isalpha():
        await update.message.reply_text("Пожалуйста, введите одну букву.")
        return

    if guess_letter in game_state[user_id]["guessed_letters"]:
        await update.message.reply_text("Вы уже называли эту букву.")
        return

    game_state[user_id]["guessed_letters"].add(guess_letter)

    if guess_letter in game_state[user_id]["secret_word"]:
        for i, letter in enumerate(game_state[user_id]["secret_word"]):
            if letter == guess_letter:
                game_state[user_id]["display_word"][i] = guess_letter

        if "_" not in game_state[user_id]["display_word"]:
            await update.message.reply_text(f"Поздравляю! Вы угадали слово: {game_state[user_id]['secret_word']}")
            new_game(user_id) # Начинаем новую игру
        else:
            await update.message.reply_text(
                f"Правильно! \nСлово: {' '.join(game_state[user_id]['display_word'])}"
                f"\nОсталось попыток: {game_state[user_id]['attempts']}"
            )
    else:
        game_state[user_id]["attempts"] -= 1
        if game_state[user_id]["attempts"] == 0:
            await update.message.reply_text(
                f"Вы проиграли! Было загадано слово: {game_state[user_id]['secret_word']}"
            )
            new_game(user_id) # Начинаем новую игру
        else:
            await update.message.reply_text(
                f"Неправильно! \nСлово: {' '.join(game_state[user_id]['display_word'])}"
                f"\nОсталось попыток: {game_state[user_id]['attempts']}"
            )

def main() -> None:
    """Запускает бота."""
    application = ApplicationBuilder().token("YOUR_BOT_TOKEN").build()

    application.add_handler(CommandHandler("start", start))

    application.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, guess))

    application.run_polling()

if __name__ == "__main__":
    main()
