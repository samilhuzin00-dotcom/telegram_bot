from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import ApplicationBuilder, CommandHandler, CallbackQueryHandler, ContextTypes
from telegram.constants import ParseMode

user_tables = {}

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обрабатывает команду /start."""
    user_id = update.effective_user.id
    keyboard = [
        [InlineKeyboardButton("Создать новую таблицу", callback_data="create_table")],
        [InlineKeyboardButton("Мои таблицы", callback_data="my_tables")]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    await update.message.reply_text("Привет! Я могу помочь вам создавать таблицы.", reply_markup=reply_markup)

async def button_click(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обрабатывает нажатия inline-кнопок."""
    query = update.callback_query
    await query.answer()
    user_id = query.from_user.id

    if query.data == "create_table":
        if user_id not in user_tables:
            user_tables[user_id] = [] # Список строк для таблицы

        user_tables[user_id].append(["Заголовок 1", "Заголовок 2", "Заголовок 3"])
        user_tables[user_id].append(["Данные 1.1", "Данные 1.2", "Данные 1.3"])
        user_tables[user_id].append(["Данные 2.1", "Данные 2.2", "Данные 2.3"])

        await query.edit_message_text("Таблица создана. Вот её содержимое:")
        await send_formatted_table(query, user_id)

    elif query.data == "my_tables":
        if user_id in user_tables and user_tables[user_id]:
            await query.edit_message_text("Вот ваши таблицы:")
            await send_formatted_table(query, user_id)
        else:
            await query.edit_message_text("У вас пока нет созданных таблиц. Создайте новую!")

async def send_formatted_table(query, user_id):
    """Форматирует и отправляет таблицу с использованием MarkdownV2."""
    table_rows = user_tables.get(user_id, [])
    if not table_rows:
        return

    formatted_text = "```\n" # Начало блока кода для выравнивания
    for row in table_rows:
        formatted_row = "|".join(str(cell).replace('.', r'\.').replace('-', r'\-') for cell in row)
        formatted_text += formatted_row + "\n"
    formatted_text += "```"

    await query.message.reply_text(formatted_text, parse_mode=ParseMode.MARKDOWN_V2)

def main() -> None:
    """Запускает бота."""
    application = ApplicationBuilder().token("YOUR_BOT_TOKEN").build()

    application.add_handler(CommandHandler("start", start))
    application.add_handler(CallbackQueryHandler(button_click))

    application.run_polling()

if __name__ == "__main__":
    main()
